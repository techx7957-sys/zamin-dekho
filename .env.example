# ==========================================
# ZAMIN DEKHO — ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git. NEVER share these values publicly.
# ==========================================


# ------------------------------------------
# 🌐 SERVER & APP
# ------------------------------------------
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000


# ------------------------------------------
# 🗄️ DATABASE — MongoDB Atlas
# ------------------------------------------
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DBNAME


# ------------------------------------------
# 🔐 AUTH SECRETS
# ------------------------------------------
# Use a long random string (>= 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_string_min_32_chars
SESSION_SECRET=replace_with_another_long_random_string


# ------------------------------------------
# 👑 ADMIN ACCESS
# ------------------------------------------
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin1@example.com,admin2@example.com
ADMIN_PHONE=+910000000000


# ------------------------------------------
# ✉️ EMAIL — Gmail App Password
# ------------------------------------------
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password_here


# ------------------------------------------
# 📞 PUBLIC CONTACT INFO (shown on contact page)
# ------------------------------------------
SUPPORT_EMAIL=support@example.com
SUPPORT_EMAILS=support@example.com,help@example.com
SUPPORT_PHONE=+910000000000
COMPANY_ADDRESS=Your Company Address Here


# ------------------------------------------
# ☁️ CLOUDINARY — image uploads
# ------------------------------------------
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# ------------------------------------------
# 🔑 GOOGLE OAUTH
# ------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Optional: full service-account JSON (single-line, escaped) for Vision API etc.
GOOGLE_CREDS_JSON={"type":"service_account",...}


# ------------------------------------------
# 🐦 TWITTER / X OAUTH 2.0
# ------------------------------------------
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your_twitter_oauth2_client_id
TWITTER_CLIENT_SECRET=your_twitter_oauth2_client_secret


# ------------------------------------------
# 📲 TWILIO — WhatsApp / SMS OTP
# ------------------------------------------
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886


# ------------------------------------------
# 💳 RAZORPAY — Payments
# ------------------------------------------
# Get from: https://dashboard.razorpay.com/app/keys
# Use TEST keys for development (rzp_test_*), LIVE keys for production (rzp_live_*)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
